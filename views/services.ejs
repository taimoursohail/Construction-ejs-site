<!DOCTYPE html>

<html class="light" lang="en">
<%- include('partials/header') %>

    <main class="pt-24">
        <!-- Hero Section -->
        <section class="relative h-[614px] flex items-center bg-inverse-surface overflow-hidden">
            <div class="absolute inset-0 opacity-40">
                <img alt="Construction site overview" class="w-full h-full object-cover"
                    data-alt="cinematic wide shot of a massive steel construction site at twilight with heavy machinery and industrial lighting casting long shadows"
                    src="https://lh3.googleusercontent.com/aida-public/AB6AXuCNFnSQDOUUQ8GjgHhIh5m0AEK-i3FJvT-Wqu3de1GZve7NcJZUDGKWJdTVuMHLgqxcPlOVEsCT-baXLuNMnuQJRzpUKf6jOQoDdS8xeRi_86BkOxyhINGQus_HH6UFiQlYCqEdxXEIzJ8uYnofBFxw6DeIhV9AES4451oxmFouqnet8zLGK6paOpvWP3pc_ZpNqfVo0QC8gewmO7ulfRgVZd8VI5Z-eZxB7wgImGE_U0UMiXpqC2y_h3m1Iwj9EQV3m2RNV1hDWio" />
            </div>
            <div class="relative z-10 px-8 md:px-20 w-full max-w-7xl">
                <p class="text-primary-container font-headline font-bold uppercase tracking-[0.3em] mb-4">CORE
                    CAPABILITIES</p>
                <h1
                    class="text-surface font-headline font-black text-6xl md:text-8xl leading-none tracking-tighter max-w-4xl">
                    PRECISION AT <br /> ANY SCALE.
                </h1>
            </div>
            <!-- Structural Accent -->
            <div class="absolute bottom-0 right-0 w-1/3 h-2 hazard-gradient"></div>
        </section>
        <!-- Services Bento Grid -->
        <section class="px-8 md:px-20 py-32 bg-surface" id="commercial">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-px bg-outline-variant/20 border border-outline-variant/20">
                <!-- Commercial -->
                <div
                    class="md:col-span-8 bg-surface p-12 flex flex-col justify-between group hover:bg-surface-container transition-colors duration-500">
                    <div>
                        <span class="material-symbols-outlined text-6xl text-primary mb-8"
                            data-icon="corporate_fare">corporate_fare</span>
                        <h3 class="text-4xl font-headline font-black uppercase tracking-tighter mb-4">Commercial
                        </h3>
                        <p class="text-secondary text-lg max-w-xl leading-relaxed">
                            Transforming urban landscapes with high-performance office towers, retail complexes, and
                            mixed-use developments that prioritize efficiency and architectural intent.
                        </p>
                    </div>
                    <div class="mt-12 flex items-center space-x-4">
                        <span class="h-px w-12 bg-primary"></span>
                        <span class="font-headline font-bold text-sm tracking-widest uppercase">View
                            Portfolio</span>
                    </div>
                </div>
                <!-- Infrastructure -->
                <div class="md:col-span-4 bg-surface-container-high p-12 flex flex-col group hover:bg-primary-container transition-colors duration-500"
                    id="commercial">
                    <span
                        class="material-symbols-outlined text-6xl text-primary group-hover:text-on-primary-container mb-8"
                        data-icon="engineering">engineering</span>
                    <h3 class="text-3xl font-headline font-black uppercase tracking-tighter mb-4">Infrastructure
                    </h3>
                    <p class="text-secondary group-hover:text-on-primary-container/80 text-base leading-relaxed">
                        Building the backbone of the future: bridges, tunnels, and civil engineering projects
                        engineered
                        for resilience and longevity.
                    </p>
                    <div class="mt-auto pt-12">
                        <img alt="Infrastructure detail"
                            class="w-full grayscale group-hover:grayscale-0 transition-all duration-700"
                            data-alt="close-up of industrial steel bridge beams and heavy bolts with a technical architectural focus and sharp precision"
                            src="https://lh3.googleusercontent.com/aida-public/AB6AXuCpYdYG8rxRhYGwVwHUYvY0Lw_vVqGTGVUEytsYpeYE-XQztxyH7UP9htCAF0u9lPJnC_nIa4t7qkREKrLEGeCtZNtaxBLUtjelRVZpJqgvl1FWbWS_Vm9jJZO1cs-sP27dnEnIs_2XJWw10zSjIgKBDe3ZBcMoMRpgQysuM9OIqB3hw3BKShbj34J1nPkww2iPXB2KoYwefnVn54x5St-HeZfxcSwedMor9l1ZlElDGaXO_EB834fF8s2JaoaN1wQNafmjmBrIZbg" />
                    </div>
                </div>
                <!-- Industrial -->
                <div class="md:col-span-5 bg-inverse-surface p-12 text-surface flex flex-col group transition-all">
                    <span class="material-symbols-outlined text-6xl text-primary-container mb-8"
                        data-icon="factory">factory</span>
                    <h3 class="text-3xl font-headline font-black uppercase tracking-tighter mb-4">Industrial</h3>
                    <p class="text-surface-variant text-base leading-relaxed mb-12">
                        Heavy-duty facilities, warehouses, and manufacturing plants designed for maximum operational
                        flow and structural durability.
                    </p>
                    <div class="h-64 bg-surface-dim relative overflow-hidden">
                        <img alt="Industrial facility" class="w-full h-full object-cover opacity-60"
                            data-alt="interior of a modern clean industrial manufacturing plant with rows of heavy machinery and high ceilings in cool tones"
                            src="https://lh3.googleusercontent.com/aida-public/AB6AXuBnmH5i5e0J32B_KzM8MDLIjjg3aiiwCZIBKVZOcaR1BZF5v4suu4S9m7Y4L2WbNDIJKLMl0QoULttenCG7pckj_pmGMibr0aokhqvfJeSwiQd65KsBuzLE3nSesHpCPmFpF-91aBAwVOCm1jtoQu3JgZuuf3ZE5-Vb0KZRjRYMEs0l31zjOO7a6F6uHeMj8rqT6GlUW8tPi3S3FOJZG2oHxQm5SHw3UxtTc1t8z6zscasp9--Y9nvgh5zD51Sxbu_EEG7MU-J2-mo" />
                    </div>
                </div>
                <!-- Education -->
                <div
                    class="md:col-span-7 bg-surface p-12 flex flex-col justify-center border-l border-outline-variant/10">
                    <div class="flex items-start space-x-8">
                        <span class="material-symbols-outlined text-7xl text-primary" data-icon="school">school</span>
                        <div>
                            <h3 class="text-4xl font-headline font-black uppercase tracking-tighter mb-4">Education
                            </h3>
                            <p class="text-secondary text-lg leading-relaxed max-w-lg">
                                Creating inspiring learning environments. From modern university campuses to
                                specialized
                                research laboratories, we build for the next generation.
                            </p>
                            <ul class="mt-8 space-y-3 font-headline font-bold uppercase tracking-tight text-sm">
                                <li class="flex items-center space-x-2"><span
                                        class="w-2 h-2 bg-primary"></span><span>Research Labs</span></li>
                                <li class="flex items-center space-x-2"><span
                                        class="w-2 h-2 bg-primary"></span><span>Student Housing</span></li>
                                <li class="flex items-center space-x-2"><span
                                        class="w-2 h-2 bg-primary"></span><span>Campus Masterplanning</span></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <!-- How We Work / Safety Process -->
        <section class="bg-surface-container-low py-32 overflow-hidden">
            <div class="px-8 md:px-20 max-w-7xl mx-auto">
                <div class="flex flex-col md:flex-row gap-20">
                    <div class="md:w-1/2">
                        <h2 class="text-5xl font-headline font-black uppercase tracking-tighter mb-8 leading-none">
                            THE
                            BLUEPRINT <br /> FOR SAFETY.</h2>
                        <p class="text-secondary text-xl mb-12 leading-relaxed">
                            Our process is built on a foundation of absolute safety. We integrate risk management
                            into
                            every phase, from the first digital twin to the final bolt.
                        </p>
                        <div class="space-y-12">
                            <!-- Process Step -->
                            <div class="flex items-start space-x-6">
                                <span
                                    class="text-4xl font-headline font-black text-primary-container [text-shadow:_-1px_-1px_0_#705d00,_1px_-1px_0_#705d00,_-1px_1px_0_#705d00,_1px_1px_0_#705d00]">01</span>
                                <div>
                                    <h4 class="font-headline font-black text-xl uppercase tracking-tight mb-2">
                                        Pre-Construction</h4>
                                    <p class="text-secondary">Rigorous site assessment, safety protocols planning,
                                        and
                                        material stress testing.</p>
                                </div>
                            </div>
                            <div class="flex items-start space-x-6">
                                <span
                                    class="text-4xl font-headline font-black text-primary-container [text-shadow:_-1px_-1px_0_#705d00,_1px_-1px_0_#705d00,_-1px_1px_0_#705d00,_1px_1px_0_#705d00]">02</span>
                                <div>
                                    <h4 class="font-headline font-black text-xl uppercase tracking-tight mb-2">
                                        Execution
                                    </h4>
                                    <p class="text-secondary">Real-time monitoring and site oversight by specialized
                                        safety supervisors.</p>
                                </div>
                            </div>
                            <div class="flex items-start space-x-6">
                                <span
                                    class="text-4xl font-headline font-black text-primary-container [text-shadow:_-1px_-1px_0_#705d00,_1px_-1px_0_#705d00,_-1px_1px_0_#705d00,_1px_1px_0_#705d00]">03</span>
                                <div>
                                    <h4 class="font-headline font-black text-xl uppercase tracking-tight mb-2">
                                        Lifecycle
                                        Management</h4>
                                    <p class="text-secondary">Handover with comprehensive structural integrity and
                                        safety documentation.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="md:w-1/2 relative">
                        <div class="aspect-square bg-surface border border-outline-variant/30 p-4 relative">
                            <img alt="Safety detail" class="w-full h-full object-cover"
                                data-alt="close up of a high-vis construction helmet and blueprints on a wooden desk with a shallow depth of field and warm natural light"
                                src="https://lh3.googleusercontent.com/aida-public/AB6AXuCr3gXSJkNPRp7ckhIgSo8DHMi7Qvmu6gUSUaG2fX3hHNGK1JPLHJmQtX4VuRcaIqDRLlujLlXSe5bbG3NVGxhmhVOFX6q4gz8O1Bk1QdibwNlMdfEtLTHlaa_qx8jXnC6MpV6ihPm5kf9xxM7RKeONLdTJPDZ1WZG6R0rD1spyiLTc-mnxOv8DbUPCnOrQQ7c1XnaRNRizmKxkLICCmEdOWjP-m7RV6H0f19sJJ9JGGSXVH8QprM6kK77MRTLrr9DK_p6LkxHpv7g" />
                            <!-- Industrial Overlay -->
                            <div
                                class="absolute -bottom-10 -left-10 w-48 h-48 bg-primary-container p-8 flex items-center justify-center">
                                <span class="material-symbols-outlined text-6xl text-on-primary-container"
                                    data-icon="health_and_safety">health_and_safety</span>
                            </div>
                            <div
                                class="absolute top-0 right-0 p-6 bg-inverse-surface text-surface font-headline font-black text-xs uppercase tracking-[0.4em] [writing-mode:vertical-lr]">
                                ZERO ACCIDENT POLICY
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <!-- CTA Section -->
        <section class="py-24 bg-primary text-on-primary text-center">
            <div class="max-w-4xl mx-auto px-8">
                <h2 class="text-5xl md:text-7xl font-headline font-black uppercase tracking-tighter mb-10 text-white">
                    READY TO BUILD?</h2>
                <button
                    class="bg-stone-900 text-white rounded-full px-12 py-5 font-headline font-black text-xl uppercase tracking-widest hover:bg-stone-800 transition-all duration-300"
                    onclick="window.open('https://taimoursohail.com/contact/', '_blank')">
                    START YOUR PROJECT
                </button>
            </div>
        </section>
    </main>
    <!-- Footer -->
    <%- include('partials/footer.ejs') %>
        </body>

</html>