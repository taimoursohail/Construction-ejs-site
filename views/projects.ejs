                        class="absolute inset-0 bg-gradient-to-t from-inverse-surface/90 via-transparent to-transparent opacity-60 group-hover:opacity-90 transition-opacity">
                    </div>
                    <div
                        class="absolute bottom-0 left-0 p-8 w-full translate-y-8 group-hover:translate-y-0 transition-transform duration-500">
                        <div class="font-headline font-black text-3xl text-white uppercase tracking-tighter mb-1">
                            Titanium Plaza</div>
                        <div class="font-label text-primary-container font-bold tracking-widest uppercase text-xs mb-4">
                            Chicago, IL</div>
                        <div class="overflow-hidden h-0 group-hover:h-auto transition-all duration-500">
                            <p class="text-surface-container-low text-sm font-light mb-6 line-clamp-3">
                                A 45-story mixed-use development featuring advanced steel fabrication and
                                carbon-neutral
                                glass systems.
                            </p>
                            <button
                                class="w-full py-4 bg-primary-container text-on-primary-container rounded-full font-headline font-bold uppercase tracking-widest hover:bg-white transition-colors">
                                View Details
                            </button>
                        </div>
                    </div>
                </div>
                <!-- Project Card 2 -->
