<!DOCTYPE html>

<html class="light" lang="en">
<%- include('partials/header') %>

    <main class="pt-32 pb-20">
        <!-- Hero Header -->
        <header class="px-8 md:px-12 mb-16">
            <div class="max-w-7xl mx-auto">
                <div class="flex items-end gap-4 mb-4">
                    <div class="h-1 w-24 bg-primary"></div>
                    <span
                        class="font-headline font-bold tracking-widest text-primary uppercase text-sm">Portfolio</span>
                </div>
                <h1
                    class="font-headline text-6xl md:text-8xl font-black tracking-tighter uppercase leading-[0.9] text-on-surface max-w-4xl">
                    Defining the <br /><span class="text-outline-variant">Modern Skyline.</span>
                </h1>
            </div>
        </header>
        <!-- Filters Section -->
        <section class="bg-surface-container-low mb-12">
            <div class="max-w-7xl mx-auto px-8 md:px-12 py-8 flex flex-wrap items-center justify-between gap-6">
                <div class="flex flex-wrap gap-4 font-headline text-sm font-bold tracking-widest uppercase">
                    <button class="px-8 py-3 bg-inverse-surface text-white rounded-full">All Projects</button>
                    <button
                        class="px-8 py-3 text-on-surface-variant hover:bg-surface-container-highest transition-colors rounded-full">Commercial</button>
                    <button
                        class="px-8 py-3 text-on-surface-variant hover:bg-surface-container-highest transition-colors rounded-full">Industrial</button>
                    <button
                        class="px-8 py-3 text-on-surface-variant hover:bg-surface-container-highest transition-colors rounded-full">Infrastructure</button>
                </div>
                <div class="flex items-center gap-2 border-b-2 border-outline-variant pb-1">
                    <span class="material-symbols-outlined text-outline">search</span>
                    <input
                        class="bg-transparent border-none focus:ring-0 font-headline text-sm tracking-widest uppercase placeholder:text-outline/50"
                        placeholder="SEARCH PROJECTS" type="text" />
                </div>
            </div>
        </section>
        <!-- Projects Grid -->
